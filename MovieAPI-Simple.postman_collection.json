							"mode": "raw",
							"raw": "{\n    \"title\": \"New Movie\",\n    \"description\": \"Movie description\",\n    \"releaseDate\": \"2024-01-15\",\n    \"rating\": 8.5,\n    \"genreIds\": [1, 2],\n    \"actorIds\": [1],\n    \"languageIds\": [1]\n}"
						},
						"url": {"raw": "{{baseUrl}}/api/Movies", "host": ["{{baseUrl}}"], "path": ["api", "Movies"]}
					},
					"response": []
				},
				{
					"name": "Update Movie",
					"request": {
						"method": "PUT",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Updated Movie Title\",\n    \"description\": \"Updated description\",\n    \"releaseDate\": \"2024-01-15\",\n    \"rating\": 9.0,\n    \"genreIds\": [1],\n    \"actorIds\": [1],\n    \"languageIds\": [1]\n}"
						},
						"url": {"raw": "{{baseUrl}}/api/Movies/1", "host": ["{{baseUrl}}"], "path": ["api", "Movies", "1"]}
					},
					"response": []
				},
